# Enphase IQ Gateway (optional — omit to disable)
ENVOY_HOST=envoy.local
ENVOY_TOKEN=your_jwt_token_here

# Tesla Wall Connector (optional — omit to disable)
TESLA_HOST=192.168.1.75
TESLA_POLL_INTERVAL_SECS=10

# EIA Gasoline Prices (optional — omit to disable)
# Get a free API key at https://www.eia.gov/opendata/
EIA_API_KEY=your_eia_api_key_here
# Region code: NUS (U.S. avg), SCA (California), SNY (New York), STX (Texas),
#   SFL (Florida), SCO (Colorado), SOH (Ohio), SMA (Massachusetts), SMN (Minnesota),
#   SWA (Washington), YBOS (Boston), YCLE (Cleveland), YDEN (Denver), YMIA (Miami),
#   YORD (Chicago), Y05LA (Los Angeles), Y05SF (San Francisco), Y35NY (NYC),
#   Y44HO (Houston), Y48SE (Seattle), or PADD regions (R10, R1X, R1Y, R1Z, R20-R50)
EIA_REGION=NUS
GAS_PRICE_POLL_INTERVAL_SECS=86400

# Database (DB_PASSWORD is used by both TimescaleDB and the collector)
DB_PASSWORD=changeme
DB_POOL_SIZE=5

# Writer
WRITE_INTERVAL_SECS=10

# Grafana
GRAFANA_PASSWORD=changeme

# Logging
RUST_LOG=info
