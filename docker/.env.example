# Enphase IQ Gateway
ENVOY_HOST=envoy.local
ENVOY_TOKEN=your_jwt_token_here

# Tesla Wall Connector
TESLA_HOST=192.168.1.75
TESLA_POLL_INTERVAL_SECS=10

# Database (DB_PASSWORD is used by both TimescaleDB and the collector)
DB_PASSWORD=changeme
DB_POOL_SIZE=5

# Writer
WRITE_INTERVAL_SECS=10

# Grafana
GRAFANA_PASSWORD=changeme

# Logging
RUST_LOG=info
